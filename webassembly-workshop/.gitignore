# =============================================================
# Rust build artifacts
# =============================================================
target/

# =============================================================
# WASM compiled outputs
# Participants compile these themselves as part of the labs.
# =============================================================
*.wasm

# AOT-precompiled WASM (generated by `wasmtime compile`)
*.cwasm

# =============================================================
# Spin binary (downloaded locally — 104 MB macOS arm64 binary)
# Install via: curl -fsSL https://developer.fermyon.com/downloads/install.sh | bash
# =============================================================
spin
spin.sig

# =============================================================
# TLS certificates (local dev only — do not commit private keys)
# =============================================================
crt.pem
*.key
*.p12
*.pem

# =============================================================
# macOS
# =============================================================
.DS_Store
**/.DS_Store
.localized

# =============================================================
# Editor / IDE
# =============================================================
.vscode/settings.json
.vscode/launch.json
.idea/
*.iml

# =============================================================
# Environment & secrets
# =============================================================
.env
.env.local
.env.*.local

# =============================================================
# Node (used by verify-setup and any JS tooling)
# =============================================================
node_modules/
npm-debug.log*

# =============================================================
# Misc
# =============================================================
*.log
